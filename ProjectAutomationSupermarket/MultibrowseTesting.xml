<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultibrowserTesting" parallel="tests">
	<test thread-count="5" name="ChromeTest">
		<parameter name="browser" value="Chrome"></parameter>
		<classes>
			<class name="testscrips.HomeTest"></class>
			<class name="testscrips.AdminUserTest"> </class>
			<class name="testscrips.ContactUsTest"> </class>
			<class name="testscrips.DashboardManageFooterTextTest"> </class>
			<class name="testscrips.ManageCategoryTest"> </class>
		</classes>
	</test>
	<test thread-count="5" name="FireFoxTest">
		<parameter name="browser" value="Firefox"></parameter>
		<classes>
			<class name="testscrips.HomeTest"> </class>
			<class name="testscrips.AdminUserTest"> </class>
			<class name="testscrips.ContactUsTest"> </class>
			<class name="testscrips.DashboardManageFooterTextTest"> </class>
			<class name="testscrips.ManageCategoryTest"> </class>
		</classes>
	</test>
</suite> <!--
Suite -->
